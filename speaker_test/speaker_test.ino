void loop() {
  // We need to play 8000 samples every second. 
  // 1 second (1,000,000 microseconds) / 8000 = 125 microseconds per sample.
  
  int totalSamples = sizeof(audio_data); // Find out how many numbers are in the array
  
  for (long i = 0; i < totalSamples; i++) {
    analogWrite(A0, audio_data[i]); // Send the audio wave to pin A0
    delayMicroseconds(125);         // Wait exactly the right amount of time for 8000Hz
  }

  // Wait 3 seconds before playing the song clip again
  delay(3000); 
}